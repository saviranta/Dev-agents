# ── OS ────────────────────────────────────────────────────────────────────────
**/.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Secrets and credentials — never commit these ──────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
credentials.json
*_credentials.json
*_secret*
api_keys*

# ── Runtime / operational files ───────────────────────────────────────────────
# These live in the project workspace (ClaudeProjects/), not in this repo.
# Guards against accidental copies landing here.
agent-workspace/
status/
**/manifest.json
**/run-log.jsonl
**/quality-log.json
**/.agent-config.json
**/signals/
**/decisions/
**/output/

# ── Project-specific docs that belong in the project, not the framework ───────
**/PRD.md
**/ADR.md
**/CONVENTIONS.md
**/DESIGN_SYSTEM.md

# ── Logs / temp ───────────────────────────────────────────────────────────────
*.log
/tmp/
